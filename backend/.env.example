# ─────────────────────────────────────────────────────────────────────────────
# Udaan — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: Full connection URL (Supabase / remote PostgreSQL)
# Use the transaction pooler (port 6543) for FastAPI / SQLAlchemy
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Alembic migrations — use direct connection (port 5432, not the pooler)
DIRECT_DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Option B: Local PostgreSQL (leave DATABASE_URL blank and fill these instead)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=yourpassword
# POSTGRES_SERVER=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=udaan_db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256

# ── Google Gemini API ─────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Email / SMTP (Gmail) ──────────────────────────────────────────────────────
# Used for OTP verification emails.
# SMTP_PASSWORD must be a Gmail App Password (not your regular Gmail password).
# Enable 2FA on your Google account, then generate an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# ── Adzuna Jobs API ───────────────────────────────────────────────────────────
# Free tier available at: https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
# Required for Google Calendar sync feature.
# 1. Create a project at https://console.cloud.google.com/
# 2. Enable Google Calendar API
# 3. Create OAuth 2.0 credentials (Desktop App)
# 4. Download credentials JSON and save as backend/data/google_credentials.json
# (this file is gitignored — never commit it)

# ── n8n Automation ────────────────────────────────────────────────────────────
# Webhook token for n8n workflow triggers (optional)
N8N_WEBHOOK_TOKEN=your_n8n_webhook_token
